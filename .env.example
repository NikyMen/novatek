# Copiá este archivo a .env y completá los valores.
# El .env real NO se commitea (está en .gitignore).

# Credenciales del panel de administración (/admin y /admin/analytics)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Secreto para firmar las cookies de sesión.
# Generá uno con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=cambiame-por-un-valor-aleatorio-largo

# Base de datos del catálogo (Neon Postgres) — opcional
DATABASE_URL=

# Ruta de la base de analíticas (opcional, default ./data/analytics.db)
# ANALYTICS_DB_PATH=/var/www/novatek/data/analytics.db
