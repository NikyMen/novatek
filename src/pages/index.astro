---
export const prerender = true;
import SiteLayout from '../layouts/SiteLayout.astro';

const WA = 'https://wa.link/fo0jrt';

const valores = [
  { t: 'Calidad', d: 'Marcas líderes seleccionadas' },
  { t: 'Precisión', d: 'Componentes que encajan' },
  { t: 'Respaldo', d: 'Soporte e instalación' },
  { t: 'Durabilidad', d: 'Piezas que aguantan los 90′' },
];

const categorias = [
  { n: 'Escuadras', img: '/img/categoria-escuadras.png' },
  { n: 'Manijas', img: '/img/categoria-manijas.png' },
  { n: 'Bisagras', img: '/img/categoria-bisagras.png' },
  { n: 'Cierres Laterales', img: '/img/categoria-cierres-laterales.png' },
  { n: 'Fallebas', img: '/img/categoria-fallebas.png' },
  { n: 'Oscilobatientes', img: '/img/categoria-oscilobatientes.png' },
  { n: 'Elevables', img: '/img/categoria-elevables.png' },
];

const marcas = [
  { n: 'Roto', img: '/img/marca-1.png' },
  { n: 'Fapim', img: '/img/marca-2.png' },
  { n: 'Monticelli', img: '/img/marca-3.png' },
  { n: 'Comunello', img: '/img/marca-4.png' },
  { n: 'Giesse', img: '/img/marca-5.png' },
];

const galeria = [
  '/img/galeria-1.png', '/img/galeria-2.png', '/img/galeria-3.png',
  '/img/galeria-4.png', '/img/galeria-5.png', '/img/galeria-6.png',
];

const campana = [
  { img: '/mundial/equipo-ganador.jpeg', t: 'Un equipo ganador no se improvisa' },
  { img: '/mundial/dirige-bandera.jpeg', t: '¿Quién dirige tu proyecto?' },
  { img: '/mundial/dirige-obra.jpeg', t: 'El DT de tu obra' },
  { img: '/mundial/levanta-copa.jpeg', t: '¿Quién levanta la copa?' },
];
---

<SiteLayout title="Novatek Argentina · Edición Mundial 2026">
  <!-- ============ HERO ============ -->
  <section class="relative isolate overflow-hidden bg-navy-gradient pt-28 md:pt-36 pb-20 md:pb-28">
    <div class="absolute inset-0 -z-10 bg-pitch-glow"></div>
    <div class="field-lines absolute inset-0 -z-10 opacity-50"></div>
    <!-- franja celeste/blanca argentina sutil -->
    <div class="absolute -top-24 -right-24 -z-10 h-[480px] w-[480px] rounded-full bg-brand-500/20 blur-[120px]"></div>
    <div class="absolute -bottom-32 -left-20 -z-10 h-[420px] w-[420px] rounded-full bg-celeste/10 blur-[120px]"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        <!-- Texto -->
        <div data-reveal>
          <div class="inline-flex items-center gap-3 rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5">
            <span class="slashes"><span></span><span></span><span></span></span>
            <span class="text-xs font-bold uppercase tracking-widest2 text-brand-300">Edición Mundial 2026</span>
          </div>

          <h1 class="mt-6 font-display text-5xl sm:text-6xl xl:text-7xl leading-[0.92] tracking-tight text-white">
            PIEZAS CLAVES<br />
            PARA <span class="text-brand-500">GRANDES</span><br />
            PROYECTOS
          </h1>

          <p class="mt-6 max-w-xl text-base md:text-lg leading-relaxed text-white/70">
            Así como una selección necesita jugadores de primer nivel, una obra necesita
            <span class="font-semibold text-white">componentes que estén a la altura</span>.
            Accesorios y herrajes para aluminio con stock real y marcas líderes.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href="/catalogo" class="group inline-flex items-center gap-2 rounded-full bg-orange-gradient px-7 py-4 font-bold text-white shadow-glow transition-transform hover:scale-105">
              Ver catálogo
              <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href={WA} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-7 py-4 font-bold text-white backdrop-blur transition-colors hover:bg-white/10">
              Contactanos
            </a>
          </div>

          <!-- mini valores -->
          <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-xl">
            {valores.map((v) => (
              <div class="flex items-center gap-2.5">
                <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-brand-500/15 text-brand-400">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="text-sm font-bold uppercase tracking-wide text-white/90">{v.t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Imagen campaña -->
        <div class="relative" data-reveal style="--reveal-delay:150ms">
          <div class="absolute inset-0 -z-10 translate-x-6 translate-y-6 rounded-[2rem] bg-brand-500/20 blur-2xl"></div>
          <div class="relative rotate-2 overflow-hidden rounded-[2rem] border border-white/10 shadow-card transition-transform duration-500 hover:rotate-0">
            <img src="/mundial/equipo-ganador.jpeg" alt="Un equipo ganador no se improvisa — Novatek" class="w-full h-auto" loading="eager" />
          </div>
          <div class="absolute -bottom-5 -left-5 hidden sm:flex items-center gap-3 rounded-2xl border border-white/10 bg-navy-800/90 px-5 py-3 shadow-card backdrop-blur">
            <span class="font-display text-3xl text-brand-500">+5</span>
            <span class="text-xs font-semibold leading-tight text-white/80">marcas<br/>internacionales</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ola inferior -->
    <div class="pointer-events-none absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-500/60 to-transparent"></div>
  </section>

  <!-- ============ TIRA DE VALORES (marquee) ============ -->
  <section class="border-y border-white/10 bg-navy-800 py-5 overflow-hidden">
    <div class="flex w-max animate-marquee gap-12 whitespace-nowrap">
      {Array.from({ length: 2 }).map(() => (
        <div class="flex items-center gap-12">
          {['Calidad', 'Precisión', 'Respaldo', 'Durabilidad', 'Seguridad', 'Stock real', 'Asesoramiento'].map((w) => (
            <span class="flex items-center gap-4">
              <span class="font-display text-2xl tracking-wide text-white/85">{w}</span>
              <span class="text-brand-500">✦</span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ============ NOSOTROS / DT ============ -->
  <section class="relative overflow-hidden py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative order-2 lg:order-1" data-reveal>
          <div class="absolute -inset-3 -z-10 rounded-[2rem] bg-gradient-to-tr from-brand-500/20 to-celeste/10 blur-xl"></div>
          <img src="/mundial/dirige-obra.jpeg" alt="¿Quién dirige tu proyecto? — Novatek" class="w-full rounded-[2rem] border border-white/10 shadow-card" loading="lazy" />
        </div>

        <div class="order-1 lg:order-2" data-reveal style="--reveal-delay:120ms">
          <div class="flex items-center gap-3">
            <span class="slashes"><span></span><span></span><span></span></span>
            <span class="text-xs font-bold uppercase tracking-widest2 text-brand-400">Sobre Novatek</span>
          </div>
          <h2 class="mt-5 font-display text-4xl md:text-5xl leading-[0.95] text-white">
            EN EL FÚTBOL HAY UN <span class="text-brand-500">DT</span>.<br />
            EN TU OBRA, ESTAMOS NOSOTROS.
          </h2>
          <p class="mt-6 text-white/70 leading-relaxed">
            En <span class="font-semibold text-white">NOVATEK</span> ofrecemos soluciones integrales en herrajes
            y accesorios para carpinterías de aluminio. Trabajamos con marcas de alta calidad, stock real
            y procesos ágiles para acompañar cada proyecto, de principio a fin.
          </p>

          <ul class="mt-8 space-y-4">
            {[
              ['Elegir el sistema correcto', 'Te ayudamos a definir la solución técnica ideal.'],
              ['Elegir materiales confiables', 'Marcas seleccionadas con respaldo internacional.'],
              ['Elegir respaldo técnico', 'Soporte para instalación y postventa.'],
            ].map(([t, d]) => (
              <li class="flex items-start gap-4">
                <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-brand-500/15 text-brand-400 ring-1 ring-brand-500/30">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <div>
                  <div class="font-bold text-white">{t}</div>
                  <div class="text-sm text-white/60">{d}</div>
                </div>
              </li>
            ))}
          </ul>

          <a href="/nosotros" class="mt-8 inline-flex items-center gap-2 font-bold text-brand-400 hover:text-brand-300 transition-colors">
            Conocé más sobre nosotros
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CATEGORÍAS / PLANTEL ============ -->
  <section class="relative py-20 md:py-28 bg-navy-800 border-y border-white/10">
    <div class="field-lines absolute inset-0 opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <div class="flex items-center justify-center gap-3">
          <span class="slashes"><span></span><span></span><span></span></span>
          <span class="text-xs font-bold uppercase tracking-widest2 text-brand-400">Nuestro plantel</span>
        </div>
        <h2 class="mt-5 font-display text-4xl md:text-5xl text-white">EL PLANTEL COMPLETO</h2>
        <p class="mt-4 text-white/65">Cada categoría es un titular. Explorá las piezas que arman tu proyecto.</p>
      </div>

      <div class="mt-14 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {categorias.map((c, i) => (
          <a href="/catalogo" class="group relative overflow-hidden rounded-2xl border border-white/10 bg-navy-900 shadow-card" data-reveal style={`--reveal-delay:${i * 70}ms`}>
            <div class="aspect-square overflow-hidden">
              <img src={c.img} alt={c.n} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/30 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 flex items-center justify-between p-4">
              <span class="font-display text-lg md:text-xl tracking-wide text-white">{c.n.toUpperCase()}</span>
              <span class="grid h-8 w-8 place-items-center rounded-full bg-brand-500 text-white opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
        <a href="/catalogo" class="group relative flex flex-col items-center justify-center gap-3 rounded-2xl border border-dashed border-brand-500/40 bg-brand-500/5 p-6 text-center transition-colors hover:bg-brand-500/10" data-reveal style={`--reveal-delay:${categorias.length * 70}ms`}>
          <span class="grid h-12 w-12 place-items-center rounded-full bg-orange-gradient text-white shadow-glow-sm">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span class="font-display text-xl text-white">VER TODO<br/>EL CATÁLOGO</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ KITS / GALERÍA DESTACADA (banners) ============ -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4" data-reveal>
        <div>
          <div class="flex items-center gap-3">
            <span class="slashes"><span></span><span></span><span></span></span>
            <span class="text-xs font-bold uppercase tracking-widest2 text-brand-400">Jugadas destacadas</span>
          </div>
          <h2 class="mt-5 font-display text-4xl md:text-5xl text-white">KITS Y SOLUCIONES</h2>
        </div>
        <p class="max-w-md text-white/60">Combinaciones listas para resolver tu obra: multipuntos, cremonas y sistemas completos.</p>
      </div>

      <div class="mt-12 -mx-4 px-4 flex snap-x snap-mandatory gap-6 overflow-x-auto pb-4 scrollbar-thin" data-reveal>
        {galeria.map((g) => (
          <figure class="snap-start shrink-0 w-[85%] sm:w-[60%] lg:w-[46%] overflow-hidden rounded-2xl border border-white/10 bg-navy-800 shadow-card">
            <img src={g} alt="Kit y solución Novatek" class="w-full h-auto" loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ ¿QUIÉN LEVANTA LA COPA? (valores) ============ -->
  <section class="relative overflow-hidden py-20 md:py-28 bg-navy-800 border-y border-white/10">
    <div class="absolute -top-24 right-1/4 h-96 w-96 rounded-full bg-gold/10 blur-[120px]"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div data-reveal>
          <div class="flex items-center gap-3">
            <span class="slashes"><span></span><span></span><span></span></span>
            <span class="text-xs font-bold uppercase tracking-widest2 text-brand-400">Lo que no puede faltar</span>
          </div>
          <h2 class="mt-5 font-display text-4xl md:text-6xl leading-[0.92] text-white">
            ¿QUIÉN <span class="text-brand-500">LEVANTA</span><br/>LA COPA?
          </h2>
          <p class="mt-6 text-white/70">¿Qué valor no puede faltar en un gran proyecto? Para nosotros, todos juegan.</p>

          <div class="mt-8 space-y-3">
            {['Calidad', 'Durabilidad', 'Seguridad', 'Respaldo técnico'].map((v, i) => (
              <div class="group flex items-center justify-between rounded-2xl border border-white/10 bg-navy-900 px-5 py-4 transition-colors hover:border-brand-500/50">
                <span class="flex items-center gap-4">
                  <span class="font-display text-xl text-brand-500/60">{i + 1}</span>
                  <span class="font-display text-xl tracking-wide text-white">{v.toUpperCase()}</span>
                </span>
                <span class="grid h-7 w-7 place-items-center rounded-full border-2 border-brand-500 text-brand-500 transition-colors group-hover:bg-brand-500 group-hover:text-white">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            ))}
          </div>
        </div>

        <div class="relative" data-reveal style="--reveal-delay:120ms">
          <div class="absolute inset-0 -z-10 scale-90 rounded-full bg-gold/20 blur-3xl"></div>
          <img src="/mundial/levanta-copa.jpeg" alt="¿Quién levanta la copa? — Novatek" class="w-full rounded-[2rem] border border-white/10 shadow-card" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MARCAS ============ -->
  <section class="py-20 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center" data-reveal>
        <h2 class="font-display text-3xl md:text-4xl text-white">MARCAS QUE NOS ACOMPAÑAN</h2>
        <p class="mt-3 text-white/55">Nuestro equipo de estrellas internacionales.</p>
      </div>
      <div class="mt-12 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5" data-reveal>
        {marcas.map((m) => (
          <div class="group grid place-items-center rounded-2xl border border-white/10 bg-white px-6 py-8 transition-transform hover:-translate-y-1">
            <img src={m.img} alt={m.n} class="h-12 w-auto object-contain opacity-90 transition group-hover:opacity-100" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CAMPAÑA MUNDIAL 2026 ============ -->
  <section class="relative overflow-hidden py-20 md:py-28 bg-navy-gradient border-y border-white/10">
    <div class="bg-pitch-glow absolute inset-0"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <div class="flex items-center justify-center gap-3">
          <span class="slashes"><span></span><span></span><span></span></span>
          <span class="text-xs font-bold uppercase tracking-widest2 text-brand-400">Campaña</span>
        </div>
        <h2 class="mt-5 font-display text-4xl md:text-5xl text-white">RUMBO AL MUNDIAL 2026</h2>
        <p class="mt-4 text-white/65">Una campaña que une la pasión del fútbol con la precisión de cada pieza.</p>
      </div>

      <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {campana.map((c, i) => (
          <figure class="group relative overflow-hidden rounded-2xl border border-white/10 shadow-card" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <img src={c.img} alt={c.t} class="aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-navy-950 to-transparent p-4 pt-10">
              <span class="text-sm font-bold text-white">{c.t}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TEASER NOVEDADES ============ -->
  <section class="relative overflow-hidden py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-[2.5rem] border border-brand-500/20 bg-navy-800 shadow-card" data-reveal>
        <div class="grid lg:grid-cols-2 items-center">
          <div class="p-8 sm:p-12 lg:p-16">
            <span class="inline-flex items-center gap-2 rounded-full bg-brand-500/15 px-4 py-1.5 text-xs font-bold uppercase tracking-widest2 text-brand-300 ring-1 ring-brand-500/30">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500"></span>
              </span>
              Muy pronto
            </span>
            <h2 class="mt-6 font-display text-4xl md:text-5xl leading-[0.95] text-white">
              ALGO GRANDE<br/><span class="text-brand-500">ESTÁ POR LLEGAR</span>
            </h2>
            <p class="mt-5 max-w-md text-white/70">
              Estamos trabajando en una alianza que va a marcar un antes y un después.
              Más tecnología, más respaldo y más oportunidades para tus proyectos.
            </p>
            <a href="/novedades" class="mt-8 inline-flex items-center gap-2 rounded-full bg-orange-gradient px-7 py-4 font-bold text-white shadow-glow transition-transform hover:scale-105">
              Descubrir qué se viene
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="relative h-full min-h-[300px]">
            <img src="/novedades-teaser/algo-grande.jpeg" alt="Algo grande está por llegar — Novatek" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-r from-navy-800 via-navy-800/30 to-transparent lg:from-navy-800 lg:via-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
