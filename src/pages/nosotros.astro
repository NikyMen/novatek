---
export const prerender = true;
import SiteLayout from '../layouts/SiteLayout.astro';

const WA = 'https://wa.link/fo0jrt';

const diferenciales = [
  { t: 'Stock real y disponibilidad inmediata', d: 'Evitá esperas y retrasos en obra. Lo que ves, está.', icon: 'box' },
  { t: 'Procesos comerciales simples y rápidos', d: 'Cotizaciones ágiles y compra sin vueltas.', icon: 'bolt' },
  { t: 'Asesoramiento técnico especializado', d: 'Un equipo que conoce cada sistema y cada pieza.', icon: 'headset' },
  { t: 'Catálogo amplio para aluminio', d: 'Soluciones nacionales e importadas en un solo lugar.', icon: 'grid' },
  { t: 'Soporte para instalación y postventa', d: 'Te acompañamos antes, durante y después.', icon: 'shield' },
  { t: 'Marcas seleccionadas', d: 'Trabajamos solo con líderes internacionales.', icon: 'star' },
];

const icons = {
  box: 'M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16zM3.27 6.96L12 12.01l8.73-5.05M12 22.08V12',
  bolt: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  headset: 'M3 18v-6a9 9 0 0118 0v6M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z',
  grid: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  star: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z',
};
---

<SiteLayout title="Nosotros · Novatek Argentina" description="En Novatek ofrecemos soluciones integrales en herrajes y accesorios para carpintería de aluminio.">
  <!-- Quiénes somos (foto arquitectura) -->
  <section class="pt-32 md:pt-40 pb-20 md:pb-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative order-2 lg:order-1" data-reveal>
          <img src="/img/nosotros-quienes-somos.png" alt="Soluciones en aluminio Novatek" class="w-full rounded-[2rem] border border-white/10 shadow-card" loading="lazy" />
        </div>
        <div class="order-1 lg:order-2" data-reveal style="--reveal-delay:120ms">
          <h2 class="font-display text-3xl md:text-4xl leading-snug text-white">
            En <span class="text-brand-500">NOVATEK</span> ofrecemos soluciones integrales en herrajes y accesorios para carpinterías de aluminio y PVC.
          </h2>
          <p class="mt-6 text-white/70 leading-relaxed">
            Trabajamos con marcas de alta calidad, stock real y procesos ágiles para acompañar cada proyecto.
          </p>
          <div id="stats-grid" class="mt-8 grid grid-cols-3 gap-4">
            {[
              { p: '+', n: 5, s: '', l: 'Marcas líderes' },
              { p: '', n: 100, s: '%', l: 'Stock real' },
              { p: '', n: 24, s: '/7', l: 'Asesoramiento' },
            ].map((stat, i) => (
              <div class="stat-card translate-y-4 rounded-2xl border border-white/10 bg-navy-800 p-4 text-center opacity-0 transition-all duration-700 ease-out" style={`transition-delay:${i * 120}ms`}>
                <div class="font-display text-3xl md:text-4xl text-brand-500 tabular-nums">
                  <span class="stat-num" data-prefix={stat.p} data-target={stat.n} data-suffix={stat.s}>{`${stat.p}0${stat.s}`}</span>
                </div>
                <div class="mt-1 text-xs text-white/60">{stat.l}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué nos diferencia -->
  <section class="py-20 md:py-24 bg-navy-800 border-y border-white/10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center" data-reveal>
        <h2 class="font-display text-4xl md:text-5xl text-white">¿QUÉ NOS DIFERENCIA?</h2>
      </div>
      <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {diferenciales.map((f, i) => (
          <div class="group rounded-3xl border border-white/10 bg-navy-900 p-7 transition-colors hover:border-brand-500/50" data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
            <div class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-500/15 text-brand-400 ring-1 ring-brand-500/30 transition-colors group-hover:bg-brand-500 group-hover:text-white">
              <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d={icons[f.icon]} stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="mt-5 text-lg font-bold text-white">{f.t}</h3>
            <p class="mt-2 text-sm text-white/60">{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Misión · Visión · Valores -->
  <section class="py-20 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            t: 'Misión',
            d: 'Brindar soluciones integrales en herrajes y accesorios para carpintería de aluminio y PVC, con stock real, marcas líderes y asesoramiento técnico que impulse cada proyecto.',
          },
          {
            t: 'Visión',
            d: 'Ser el socio de referencia del rubro, reconocidos por la calidad de nuestros productos, la agilidad de nuestros procesos y la confianza de quienes nos eligen.',
          },
          {
            t: 'Valores',
            d: 'Calidad, compromiso, respaldo y cercanía. Trabajamos con seriedad y un equipo técnico que entiende lo que tu obra necesita para ganar.',
          },
        ].map((item, i) => (
          <div class="group rounded-3xl border border-white/10 bg-navy-800 p-8 shadow-card transition-colors hover:border-brand-500/50" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <div class="flex items-center gap-3">
              <span class="slashes"><span></span><span></span><span></span></span>
              <h3 class="font-display text-2xl tracking-wide text-white">{item.t.toUpperCase()}</h3>
            </div>
            <p class="mt-4 text-white/70 leading-relaxed">{item.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-navy-800 px-8 py-14 text-center shadow-card" data-reveal>
        <div class="bg-pitch-glow absolute inset-0"></div>
        <h2 class="relative font-display text-3xl md:text-5xl text-white">JUGÁ CON UN EQUIPO GANADOR</h2>
        <p class="relative mx-auto mt-4 max-w-xl text-white/70">Conectate con nuestro equipo y obtené asesoramiento técnico personalizado.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="relative mt-8 inline-flex items-center gap-2 rounded-full bg-orange-gradient px-8 py-4 font-bold text-white shadow-glow transition-transform hover:scale-105">
          Contactanos
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const grid = document.getElementById('stats-grid');
      if (!grid) return;
      const cards = Array.from(grid.querySelectorAll('.stat-card'));
      const nums = Array.from(grid.querySelectorAll('.stat-num'));

      function countUp(el) {
        const target = Number(el.dataset.target) || 0;
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        const dur = 1400;
        const start = performance.now();
        function frame(now) {
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
          el.textContent = prefix + Math.round(eased * target) + suffix;
          if (t < 1) requestAnimationFrame(frame);
          else el.textContent = prefix + target + suffix;
        }
        requestAnimationFrame(frame);
      }

      function run() {
        cards.forEach((c) => c.classList.remove('opacity-0', 'translate-y-4'));
        nums.forEach((n) => countUp(n));
      }

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        cards.forEach((c) => c.classList.remove('opacity-0', 'translate-y-4'));
        nums.forEach((n) => (n.textContent = (n.dataset.prefix || '') + (n.dataset.target || '') + (n.dataset.suffix || '')));
        return;
      }

      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            run();
            io.disconnect();
          }
        });
      }, { threshold: 0.4 });
      io.observe(grid);
    })();
  </script>
</SiteLayout>
