---
export const prerender = true;
import SiteLayout from '../layouts/SiteLayout.astro';

const WA = 'https://wa.link/fo0jrt';

const categorias = [
  { n: 'Escuadras', img: '/img/categoria-escuadras.png', d: 'Escuadras de unión y refuerzo para estructuras de aluminio.' },
  { n: 'Manijas', img: '/img/categoria-manijas.png', d: 'Manijas y manillones de línea para abrir y cerrar con precisión.' },
  { n: 'Bisagras', img: '/img/categoria-bisagras.png', d: 'Bisagras de alto rendimiento para puertas y ventanas.' },
  { n: 'Cierres Laterales', img: '/img/categoria-cierres-laterales.png', d: 'Sistemas de cierre lateral seguros y duraderos.' },
  { n: 'Fallebas', img: '/img/categoria-fallebas.png', d: 'Fallebas y cierres perimetrales para máxima hermeticidad.' },
  { n: 'Oscilobatientes', img: '/img/categoria-oscilobatientes.png', d: 'Mecanismos oscilobatientes (tilt & turn) de marcas líderes.' },
  { n: 'Elevables', img: '/img/categoria-elevables.png', d: 'Herrajes para sistemas elevables de grandes paños.' },
];

const galeria = [
  '/img/galeria-1.png', '/img/galeria-2.png', '/img/galeria-3.png',
  '/img/galeria-4.png', '/img/galeria-5.png', '/img/galeria-6.png',
];

const marcas = [
  { n: 'Roto', img: '/img/marca-1.png' },
  { n: 'Fapim', img: '/img/marca-2.png' },
  { n: 'Monticelli', img: '/img/marca-3.png' },
  { n: 'Comunello', img: '/img/marca-4.png' },
  { n: 'Giesse', img: '/img/marca-5.png' },
];
---

<SiteLayout title="Catálogo · Novatek Argentina" description="Catálogo de herrajes y accesorios para aluminio: escuadras, manijas, bisagras, fallebas, oscilobatientes y más.">
  <!-- Encabezado -->
  <section class="relative overflow-hidden bg-navy-gradient pt-32 md:pt-40 pb-16">
    <div class="bg-pitch-glow absolute inset-0"></div>
    <div class="field-lines absolute inset-0 opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <div class="flex items-center justify-center gap-3">
        <span class="slashes"><span></span><span></span><span></span></span>
        <span class="text-xs font-bold uppercase tracking-widest2 text-brand-400">Catálogo</span>
      </div>
      <h1 class="mt-5 font-display text-5xl md:text-6xl text-white">EL PLANTEL COMPLETO</h1>
      <p class="mx-auto mt-4 max-w-2xl text-white/65">
        Calidad, precisión y disponibilidad inmediata. Explorá nuestras categorías y consultá
        stock y precios con nuestro equipo.
      </p>
    </div>
  </section>

  <!-- Categorías -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {categorias.map((c, i) => (
          <article class="group flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-navy-800 shadow-card" data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
            <div class="relative aspect-[4/3] overflow-hidden">
              <img src={c.img} alt={c.n} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-900/80 to-transparent"></div>
              <span class="absolute left-4 top-4 rounded-full bg-navy-950/80 px-3 py-1 text-[10px] font-bold uppercase tracking-widest2 text-brand-300 ring-1 ring-white/10 backdrop-blur">
                Disponible
              </span>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-2xl tracking-wide text-white">{c.n.toUpperCase()}</h3>
              <p class="mt-2 flex-1 text-sm text-white/60">{c.d}</p>
              <a href={WA} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex items-center justify-center gap-2 rounded-full border border-brand-500/40 bg-brand-500/10 px-5 py-3 text-sm font-bold text-brand-300 transition-colors hover:bg-brand-500 hover:text-white">
                Consultar stock
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Kits destacados -->
  <section class="py-16 md:py-20 bg-navy-800 border-y border-white/10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center" data-reveal>
        <h2 class="font-display text-4xl md:text-5xl text-white">KITS Y SOLUCIONES</h2>
        <p class="mt-3 text-white/60">Sistemas completos listos para resolver tu obra.</p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 gap-6" data-reveal>
        {galeria.map((g) => (
          <figure class="overflow-hidden rounded-2xl border border-white/10 bg-navy-900 shadow-card">
            <img src={g} alt="Kit y solución Novatek" class="w-full h-auto" loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Marcas -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center" data-reveal>
        <h2 class="font-display text-3xl md:text-4xl text-white">MARCAS QUE NOS ACOMPAÑAN</h2>
      </div>
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5" data-reveal>
        {marcas.map((m) => (
          <div class="grid place-items-center rounded-2xl border border-white/10 bg-white px-6 py-8 transition-transform hover:-translate-y-1">
            <img src={m.img} alt={m.n} class="h-11 w-auto object-contain" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-orange-gradient px-8 py-12 text-center shadow-glow" data-reveal>
        <h2 class="font-display text-3xl md:text-4xl text-white">¿NO ENCONTRÁS LA PIEZA QUE BUSCÁS?</h2>
        <p class="mx-auto mt-3 max-w-xl text-white/90">Contanos qué necesitás y nuestro equipo te arma la solución a medida.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="mt-7 inline-flex items-center gap-2 rounded-full bg-navy-900 px-8 py-4 font-bold text-white transition-transform hover:scale-105">
          Hablar con un asesor
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
