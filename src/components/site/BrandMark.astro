---
// Marca "N" de Novatek recreada como SVG (nítida en cualquier tamaño)
export interface Props {
  class?: string;
}
const { class: className = 'h-10 w-10' } = Astro.props;
---

<svg class={className} viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <!-- N en blanco -->
  <g fill="currentColor">
    <rect x="22" y="22" width="18" height="76" rx="1" />
    <rect x="80" y="22" width="18" height="76" rx="1" />
    <polygon points="22,22 40,22 98,98 80,98" />
  </g>
  <!-- Acento naranja (esquina inferior izquierda) -->
  <polygon points="22,98 22,66 40,98" fill="#F26A1B" />
</svg>
