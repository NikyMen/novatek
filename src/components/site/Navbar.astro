---
import BrandMark from './BrandMark.astro';

const WA = 'https://wa.link/fo0jrt';
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/novedades', label: 'Novedades' },
  { href: '/contacto', label: 'Contacto' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  id="site-nav"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 border-b border-white/0"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 md:h-20 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="group flex items-center gap-3">
        <span class="text-white transition-transform group-hover:scale-105">
          <BrandMark class="h-9 w-9 md:h-10 md:w-10" />
        </span>
        <span class="leading-none">
          <span class="block font-display text-xl md:text-2xl tracking-wide text-white">NOVATEK</span>
          <span class="mt-0.5 hidden lg:block whitespace-nowrap text-[10px] uppercase tracking-[0.18em] text-brand-400 font-semibold">
            Piezas claves para grandes proyectos
          </span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {
          links.map((l) => {
            const active = path === l.href.replace(/\/$/, '') || (l.href === '/' && path === '/');
            return (
              <a
                href={l.href}
                class={`relative px-4 py-2 text-sm font-semibold uppercase tracking-wide transition-colors ${
                  active ? 'text-brand-400' : 'text-white/80 hover:text-white'
                }`}
              >
                {l.label}
                <span
                  class={`absolute left-4 right-4 -bottom-0.5 h-0.5 bg-brand-500 origin-left transition-transform ${
                    active ? 'scale-x-100' : 'scale-x-0'
                  }`}
                />
              </a>
            );
          })
        }
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-3 inline-flex items-center gap-2 rounded-full bg-orange-gradient px-5 py-2.5 text-sm font-bold text-white shadow-glow-sm transition-transform hover:scale-105"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.59 5.39l-.999 3.648 3.908-1.025zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.078 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          Contactanos
        </a>
      </nav>

      <!-- Mobile toggle -->
      <button
        id="nav-toggle"
        class="md:hidden inline-flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 text-white ring-1 ring-white/15"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg id="ic-open" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/></svg>
        <svg id="ic-close" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-white/10 bg-navy-900/98 backdrop-blur-xl"
  >
    <nav class="mx-auto max-w-7xl px-4 py-4 flex flex-col gap-1">
      {
        links.map((l) => (
          <a href={l.href} class="rounded-xl px-4 py-3 text-base font-semibold text-white/90 hover:bg-white/10 hover:text-brand-400 transition-colors">
            {l.label}
          </a>
        ))
      }
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center justify-center gap-2 rounded-xl bg-orange-gradient px-5 py-3.5 text-base font-bold text-white"
      >
        Contactanos por WhatsApp
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const nav = document.getElementById('site-nav');
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    const open = document.getElementById('ic-open');
    const close = document.getElementById('ic-close');

    function onScroll() {
      if (window.scrollY > 24) {
        nav.classList.add('bg-navy-900/85', 'backdrop-blur-xl', 'border-white/10', 'shadow-card');
      } else {
        nav.classList.remove('bg-navy-900/85', 'backdrop-blur-xl', 'border-white/10', 'shadow-card');
      }
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    toggle?.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      open.classList.toggle('hidden', !isOpen);
      close.classList.toggle('hidden', isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
    menu?.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        menu.classList.add('hidden');
        open.classList.remove('hidden');
        close.classList.add('hidden');
      })
    );
  })();
</script>
